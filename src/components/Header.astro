---
import ThemeToggle from './ThemeToggle';

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 border-b border-gray-200 bg-white/80 backdrop-blur-sm dark:border-gray-700 dark:bg-gray-900/80"
>
  <div class="container-width">
    <div class="flex h-16 items-center justify-between">
      <a href="/" class="text-xl font-bold transition-opacity hover:opacity-80">
        Accio <span class="text-accent">Blog</span>
      </a>

      <nav aria-label="メインナビゲーション" class="flex items-center gap-6">
        {
          navItems.map(({ href, label }) => {
            const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href));
            return (
              <a
                href={href}
                aria-current={isActive ? 'page' : undefined}
                class:list={[
                  'text-sm font-medium transition-colors',
                  isActive ? 'text-accent' : 'text-gray-600 hover:text-accent dark:text-gray-300',
                ]}
              >
                {label}
              </a>
            );
          })
        }
        <ThemeToggle client:idle />
      </nav>
    </div>
  </div>
</header>
