---
interface Props {
  title: string;
  description: string;
  tags: string[];
  publishedAt: Date;
  slug: string;
}

const { title, description, tags, publishedAt, slug } = Astro.props;

const formattedDate = publishedAt.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article
  class="group rounded-xl border border-gray-200 p-6 transition-colors hover:border-accent dark:border-gray-700 dark:hover:border-accent"
>
  <a href={`/blog/${slug}/`} class="block">
    <time datetime={publishedAt.toISOString()} class="text-sm text-gray-500 dark:text-gray-400">
      {formattedDate}
    </time>
    <h3 class="mt-2 text-xl font-bold transition-colors group-hover:text-accent">
      {title}
    </h3>
    <p class="mt-2 line-clamp-2 text-gray-600 dark:text-gray-300">
      {description}
    </p>
  </a>
  <div class="mt-4 flex flex-wrap gap-2">
    {
      tags.map((tag) => (
        <a
          href={`/blog/tag/${tag}`}
          class="rounded-full bg-gray-100 px-2 py-1 text-xs text-gray-600 transition-colors hover:bg-accent hover:text-white dark:bg-gray-800 dark:text-gray-300"
        >
          {tag}
        </a>
      ))
    }
  </div>
</article>
