---
interface Props {
  tags: string[];
  activeTag?: string;
}

const { tags, activeTag } = Astro.props;
---

<div class="flex flex-wrap gap-2">
  <a
    href="/blog"
    class:list={[
      'rounded-full px-3 py-1 text-sm transition-colors',
      !activeTag
        ? 'bg-accent text-white'
        : 'bg-gray-100 text-gray-600 hover:bg-accent hover:text-white dark:bg-gray-800 dark:text-gray-300',
    ]}
  >
    All
  </a>
  {
    tags.map((tag) => (
      <a
        href={`/blog/tag/${tag}`}
        class:list={[
          'rounded-full px-3 py-1 text-sm transition-colors',
          activeTag === tag
            ? 'bg-accent text-white'
            : 'bg-gray-100 text-gray-600 hover:bg-accent hover:text-white dark:bg-gray-800 dark:text-gray-300',
        ]}
      >
        {tag}
      </a>
    ))
  }
</div>
