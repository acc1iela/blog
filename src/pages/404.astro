---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="404 - ページが見つかりません" description="お探しのページは存在しないか、移動した可能性があります。">
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <p class="text-8xl font-bold text-accent">404</p>
    <h1 class="mt-4 text-2xl font-semibold">ページが見つかりません</h1>
    <p class="mt-3 text-gray-500 dark:text-gray-400">
      お探しのページは存在しないか、移動した可能性があります。
    </p>
    <a
      href="/"
      class="mt-8 rounded-lg bg-accent px-6 py-3 font-medium text-white transition-opacity hover:opacity-80"
    >
      ホームへ戻る
    </a>
  </div>
</BaseLayout>
