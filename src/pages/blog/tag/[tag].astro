---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import TagList from '@/components/TagList.astro';
import { getCollection } from 'astro:content';
import { sortByDate, getAllTags, getSlug } from '@/utils/posts';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const allTags = getAllTags(allPosts);

  return allTags.map((tag) => ({
    params: { tag },
    props: {
      posts: sortByDate(allPosts.filter((post) => post.data.tags.includes(tag))),
      allTags,
    },
  }));
}

interface Props {
  posts: Awaited<ReturnType<typeof getCollection<'blog'>>>;
  allTags: string[];
}

const { tag } = Astro.params;
const { posts, allTags } = Astro.props;
---

<BaseLayout title={`${tag}の記事`} description={`${tag}に関する記事一覧`}>
  <section class="py-8">
    <h1 class="mb-2 text-3xl font-bold">
      <span class="text-accent">#{tag}</span> の記事
    </h1>
    <p class="mb-8 text-gray-500 dark:text-gray-400">
      {posts.length}件の記事
    </p>

    <div class="mb-8">
      <TagList tags={allTags} activeTag={tag} />
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      {
        posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            tags={post.data.tags}
            publishedAt={post.data.publishedAt}
            slug={getSlug(post)}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
